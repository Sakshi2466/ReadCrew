# Create .gitignore with these contents
cat > .gitignore << EOF
# Environment files
.env
.env.local
.env.production
.env.development
*.env

# Dependencies
node_modules/
*/node_modules/

# Build outputs
dist/
build/
*.log

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Backend specific
backend/.env
backend/node_modules/

# Frontend specific
frontend/node_modules/
frontend/dist/

# Temporary files
*.tmp
*.temp
EOF