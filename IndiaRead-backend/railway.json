{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd IndiaRead-backend/backend && npm install"
  },
  "deploy": {
    "startCommand": "cd IndiaRead-backend/backend && node server.js",
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE"
  }
}